# kienzlefon
# Version: 1.9
# Changelog:
# - 1.9: Optionale Rufnummernanonymisierung fuer Demoausgaben ergaenzt.
# - 1.8.2: Notrufnummern als Woerter und Geburtstag in Fallback-Ansagen gesetzt.
# - 1.8.1: Konfigurationsvorlage unveraendert fuer das Rechte-Patchrelease uebernommen.
# - 1.8: Expliziten, standardmaessig deaktivierten Telepraxis-Demomodus ergaenzt.
# - 1.7.1: Rottelefon-Mitgliedschaft der Sonderqueue als Laufzeitverhalten dokumentiert.
# - 1.7: Optionales rotes Telefon und priorisierte Sonderqueue ergaenzt.
# - 1.6: Drei Whisper-Modellbereiche und feldbezogene Initial-Prompts ergaenzt.
# - 1.5: 16-kHz-Ansagenaufnahme und gemeinsame Lautheitsziele ergaenzt.
# - 1.4: PIN entfernt und Ansagen-IVR sprachlich ueberarbeitet.
# - 1.3: Ansagenverwaltung, Zusatztelefone und Wahlregeln ergaenzt.
# - 1.2: Erfassungs- und Ansagelogik der Zeitprofile dokumentiert.
# - 1.1: TTS-Pausen sowie IVR- und Notfalltelefonparameter ergaenzt.
# - 1.0: Vollstaendige Erstkonfiguration fuer IVR, Whisper und Telepraxis.

[pfade]
spool = "/var/spool/asterisk/kienzlefon"
runtime = "/run/kienzlefon"
ansagen = "/var/lib/asterisk/sounds/kienzlefon"
ansagen_master = "/var/lib/kienzlefon/ansagen-master"

[praxis]
name = "Praxisname"
zeitzone = "Europe/Berlin"

[override]
aktiv = false
ansage = ""
telefonzeiten_sperren = true

[ivr]
menue_durchlaeufe = 2
tasten_timeout_ms = 6000
ansage_pause_ms = 700
queue = "praxis"
queue_context = "kfx-phone-queue,s,1"
apotheken_prioritaet = 10
rotes_telefon_aktiv = true
rote_nebenstelle = "299"
rotes_telefon_klingeldauer_sekunden = 20
rotes_telefon_queue_prioritaet = 100
fachstellen_ansage = false

[aufnahme]
format = "wav"
stille_kurz_sekunden = 3
stille_lang_sekunden = 6
maximum_kurz_sekunden = 30
maximum_lang_sekunden = 180
verwaist_sekunden = 7200

[whisper]
modell_standard = "large-v3-turbo"
modell_namen = "large-v3"
modell_medikamente = "large-v3-turbo"
initial_prompt_vorname = "Es folgt ausschließlich der Vorname einer Person."
initial_prompt_nachname = "Es folgt ausschließlich der Familienname einer Person."
initial_prompt_medikamente = "Es folgt eine Medikamentenangabe mit Medikamentenname oder Wirkstoff, Wirkstärke und Packungsgröße."
modellverzeichnis = "/var/lib/kienzlefon/models"
geraet = "cpu"
compute_type = "int8"
cpu_threads = 0
beam_size = 5
sprache = "de"
poll_sekunden = 0.5
heartbeat_sekunden = 5
heartbeat_veraltet_sekunden = 20
maximale_versuche = 3

[telepraxis]
kanal = "dahl"
ausgabeverzeichnis = "/srv/telepraxis/dahl/inbox"
demo = false
anrufernummern_anonymisieren = false
public_key = "/etc/kienzlefon/telepraxis-public.pem"

[tts]
engine = "piper"
stimme = "de_DE-thorsten-high"
stimmenverzeichnis = "/var/lib/kienzlefon/piper-voices"
uploadverzeichnis = "/var/lib/kienzlefon/ansagen-upload"
lautstaerke = 1.0
length_scale = 1.3
sentence_silence = 0.8
ziel_lautheit_lufs = -19.0
max_true_peak_db = -2.0

[asterisk]
rotes_telefon_passwort = "CHANGE_ME_RED_PHONE_SECRET"
telefon_transport = "transport-kfx-phone"
hauptausgang_endpoint = "kfx-phone-in-endpoint"
hauptausgang_nummer = "CHANGE_ME_MAIN_NUMBER"
ausgehend_zaehlt_kanalgrenze = true
erste_queue_nebenstelle = 201
queue_nebenstellen_anzahl = 1

[ansagen_ivr]
nebenstelle = "777"
aufnahme_stille_sekunden = 3
aufnahme_max_sekunden = 180
audit_log = "/var/lib/kienzlefon/ansagen-ivr-audit.jsonl"

[zusaetzliche_nebenstellen]
nebenstellen = []
passwoerter = []

[sonderqueue]
# Ein aktiviertes rotes Telefon wird automatisch ebenfalls Mitglied dieser Queue.
name = "kienzlefon-sonder"
gewicht = 100
zusaetzliche_nebenstellen = []

[wahlregeln]
landesvorwahl = "49"
ortsvorwahl = "02331"
praxisrufnummer = "123456"
min_extern_ziffern = 3
international_gesperrt = true
sperre_0900 = true
sperre_0137 = true
sperre_118 = true
sperre_019 = true
sperre_0180 = false
sperre_0700 = false
sperre_032 = false
audit_log = "/var/lib/kienzlefon/telefonie-audit.jsonl"

[sip_direkte_queue]
aktiv = false
rufnummer = ""
benutzer = ""
passwort = ""
domain = ""
outbound_proxy = ""
expiration = 300
ausgehend_verwenden = false

[sip_rotes_telefon]
aktiv = false
rufnummer = ""
benutzer = ""
passwort = ""
domain = ""
outbound_proxy = ""
expiration = 300
ausgehend_verwenden = false

# Zeitformat direkt in TOML: ["10:00-16:00"]
# Mehrere Zeitraeume: ["08:00-12:00", "14:00-17:00"]
# Im Installer werden Zeiten ohne eckige Klammern eingegeben.
# Gemeinsame Vormittage Montag bis Freitag stehen jeweils als erster Zeitraum.
[oeffnungszeiten]
montag = []
dienstag = []
mittwoch = []
donnerstag = []
freitag = []
samstag = []
sonntag = []

[telefonzeiten]
montag = []
dienstag = []
mittwoch = []
donnerstag = []
freitag = []
samstag = []
sonntag = []

[apothekenzeiten]
montag = []
dienstag = []
mittwoch = []
donnerstag = []
freitag = []
samstag = []
sonntag = []

[fachstellenzeiten]
montag = []
dienstag = []
mittwoch = []
donnerstag = []
freitag = []
samstag = []
sonntag = []

[ansagen]
greeting_open = "Guten Tag, Sie sind verbunden mit der Praxis {praxisname}. Die Praxis ist momentan geöffnet."
greeting_closed = "Guten Tag, Sie sind verbunden mit der Praxis {praxisname}. Die Praxis ist momentan geschlossen."
emergency = "Bei lebensbedrohlichen Notfällen wählen Sie bitte sofort die eins eins zwei."
urgent_help = "Bei dringenden Beschwerden außerhalb unserer Sprechzeiten wenden Sie sich bitte an den ärztlichen Bereitschaftsdienst unter eins eins sechs, eins eins sieben."
menu_intro = "Bitte wählen Sie nun durch Tastendruck auf Ihrem Telefon eine der folgenden Möglichkeiten."
menu_open = "Wenn Sie persönlich mit der Praxis sprechen möchten, drücken Sie 1. Für ein Rezept drücken Sie 2. Für eine Überweisung drücken Sie 3. Für einen Termin drücken Sie 4. Für eine Rückrufbitte oder ein sonstiges Anliegen drücken Sie 5."
menu_closed = "Für ein Rezept drücken Sie 2. Für eine Überweisung drücken Sie 3. Für einen Termin drücken Sie 4. Für eine Rückrufbitte oder ein sonstiges Anliegen drücken Sie 5."
