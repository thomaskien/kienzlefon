admin_special_menu = "Für die Feiertags- und Sonderansage stehen folgende Möglichkeiten zur Verfügung. Zum Aktivieren bei weiterhin gültigen Telefonzeiten drücken Sie 1. Zum Aktivieren und gleichzeitigen Sperren der Telefonzeiten drücken Sie 2. Zum Deaktivieren drücken Sie 3. Für den aktuellen Status drücken Sie 4. Zurück mit 0."
admin_special_keep = "Die Feiertags- und Sonderansage ist jetzt aktiv. Die regulären Telefonzeiten bleiben gültig."
admin_special_block = "Die Feiertags- und Sonderansage ist jetzt aktiv. Die regulären Telefonzeiten sind gesperrt."
admin_special_disabled = "Die Feiertags- und Sonderansage wurde deaktiviert."
