next_medication = "Bitte nennen Sie das nächste Medikament mit Wirkstärke und Packungsgröße."
medication_choice = "Für ein weiteres Medikament drücken Sie 1. Wenn Ihre Bestellung vollständig ist, drücken Sie 2."
specialty = "Für welche Fachrichtung benötigen Sie die Überweisung?"
referral_reason = "Bitte nennen Sie den Grund für die Überweisung."
appointment = "Bitte schildern Sie Ihren Terminwunsch."
callback_reason = "Bitte schildern Sie den Grund für Ihren Rückrufwunsch."
